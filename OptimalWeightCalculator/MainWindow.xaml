<Window x:Class="OptimalWeightCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор оптимального веса" Height="450" Width="500"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Калькулятор оптимального веса" 
                   FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Пол:" VerticalAlignment="Center" Margin="5"/>
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="5">
            <RadioButton x:Name="rbMale" Content="Мужчина" IsChecked="True" Margin="0,0,15,0"/>
            <RadioButton x:Name="rbFemale" Content="Женщина"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Рост (см):" VerticalAlignment="Center" Margin="5"/>
        <TextBox x:Name="tbHeight" Grid.Row="2" Grid.Column="1" Width="150" HorizontalAlignment="Left" Margin="5"/>
        <TextBlock Grid.Row="2" Grid.Column="1" Text="130-220 см" Margin="160,5,0,0" Foreground="Gray"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Вес (кг):" VerticalAlignment="Center" Margin="5"/>
        <TextBox x:Name="tbWeight" Grid.Row="3" Grid.Column="1" Width="150" HorizontalAlignment="Left" Margin="5"/>
        <TextBlock Grid.Row="3" Grid.Column="1" Text="40-170 кг" Margin="160,5,0,0" Foreground="Gray"/>

        <Button x:Name="btnCalculate" Grid.Row="4" Grid.ColumnSpan="2" Content="Рассчитать" 
                Width="150" Height="30" HorizontalAlignment="Center" Margin="5" Click="BtnCalculate_Click"/>

        <TextBlock Grid.Row="5" Grid.ColumnSpan="2" Text="Результат:" FontWeight="Bold" Margin="5"/>
        <TextBlock x:Name="tbResult" Grid.Row="6" Grid.ColumnSpan="2" TextWrapping="Wrap" Margin="5"/>
    </Grid>
</Window>